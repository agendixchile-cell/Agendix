# Supabase — obtén estos valores en supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# URLs publicas de producto
# Local: http://localhost:3000
# Produccion: https://app.agendixchile.cl
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MARKETING_URL=https://www.agendixchile.cl

# URL publica usada por Edge Functions para links en correos.
# En produccion debe apuntar al dominio de la app.
APP_BASE_URL=http://localhost:3000

# Opcional para endpoints server-side públicos como reserva online.
# Nunca exponer en cliente.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Resend para recordatorios y SMTP de Supabase Auth.
# Para aplicar supabase/config.toml, exporta RESEND_API_KEY localmente antes de `supabase config push`.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Agendix <recordatorios@agendixchile.cl>"

# Mercado Pago para cobros de pacientes.
# Configura el webhook hacia /api/webhooks/mercado-pago.
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-...
MERCADO_PAGO_PUBLIC_KEY=APP_USR-...
MERCADO_PAGO_WEBHOOK_SECRET=...

# WhatsApp Business Cloud API para confirmaciones 24h antes.
# Usa WHATSAPP_MODE=mock solo para pruebas sin enviar mensajes reales.
WHATSAPP_MODE=live
WHATSAPP_ACCESS_TOKEN=...
WHATSAPP_PHONE_NUMBER_ID=...
WHATSAPP_GRAPH_VERSION=v25.0
WHATSAPP_TEMPLATE_NAME=agendix_confirmacion_cita_24h
WHATSAPP_TEMPLATE_LANGUAGE=es_CL

# Modo demo controlado.
# Local legacy: AGENDIX_DEMO_MODE=true
# Preview/staging: habilita ambas para mostrar accesos demo y sincronizar selector.
# No lo actives en producción real con datos de pacientes.
# AGENDIX_DEMO_ENABLED=true
# NEXT_PUBLIC_AGENDIX_DEMO_ENABLED=true
# AGENDIX_DEMO_PLAN=individual # individual | center | center_pro | enterprise

# Piloto productivo cerrado:
# Production debe usar un proyecto Supabase production separado, sin datos demo,
# con backups activos y estas variables demo apagadas o ausentes:
# AGENDIX_DEMO_ENABLED=false
# NEXT_PUBLIC_AGENDIX_DEMO_ENABLED=false
#
# Staging/preview/demo comercial deben usar otro proyecto Supabase con datos
# ficticios o anonimizados. Nunca conectar entornos demo a Supabase production.
