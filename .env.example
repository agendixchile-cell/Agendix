# Supabase — obtén estos valores en supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
NEXT_PUBLIC_APP_URL=https://app.agendixchile.cl

# Opcional para endpoints server-side públicos como reserva online.
# Nunca exponer en cliente.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Modo demo — solo para desarrollo local, nunca en producción ni staging
# AGENDIX_DEMO_MODE=true
